# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — it must NEVER be committed.

# === Supabase ===
# Get these from https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# === Stripe ===
# Get these from https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# After you set up the webhook (see README), Stripe gives you this signing secret:
STRIPE_WEBHOOK_SECRET=whsec_xxx

# === Site ===
# In production, set this to your portal's public URL (e.g. https://portal.hellostudio.online)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
